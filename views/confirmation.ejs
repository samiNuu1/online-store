<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>order confirmation</title>
</head>
<body>

    <h2>Order #<%= order.id %></h2>
    <p>Status: <%= order.status %></p>
    <p>Date: <%= order.created_at %></p>

        <table>
      <tr>
        <th>Name</th>
        <th>Quantity</th>
        <th>Price</th>
      </tr>
      <% orderItems.forEach(item => { %>
      <tr>
        <td><%= item.name %></td>
        <td><%= item.quantity %></td>
        <td><%= item.price %></td>
      </tr>
      <% }) %>
    </table>
</body>
</html>